{
  "name": "call-calendar",
  "version": "1.0.0",
  "private": true,
  "description": "Call calendar API contract (Design First with TypeSpec)",
  "scripts": {
    "compile": "tsp compile .",
    "compile:watch": "tsp compile . --watch",
    "start": "node backend/dist/index.js",
    "start:test": "concurrently \"npm run dev --prefix backend\" \"npm run dev --prefix frontend\"",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed"
  },
  "devDependencies": {
    "@playwright/test": "^1.50.0",
    "@types/node": "^26.1.1",
    "@typespec/compiler": "^1.13.0",
    "@typespec/http": "^1.13.0",
    "@typespec/openapi3": "^1.13.0",
    "concurrently": "^8.2.2"
  }
}
